# NVIDIA NIM API — used for content analysis (Kimi K2.5)
NVIDIA_API_KEY=nvapi-your-nvidia-key

# Groq API — used for Whisper transcription only
GROQ_API_KEY=gsk_your-groq-key-for-whisper

# Multiple Groq keys for rotation (comma-separated, takes priority over GROQ_API_KEY)
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
