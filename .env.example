# NVIDIA NIM API — used for content analysis (Kimi K2.5)
NVIDIA_API_KEY=nvapi-your-nvidia-key

# Groq API — used for Whisper transcription only
GROQ_API_KEY=gsk_your-groq-key-for-whisper

# Multiple Groq keys for rotation (comma-separated, takes priority over GROQ_API_KEY)
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Stripe — used for payments
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_AGENCY_PRICE_ID=price_your-agency-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# JWT — used for user authentication
JWT_SECRET=generate-a-random-64-char-string-here
